#include <stdio.h>

int main() {
    int arr[10]={10,20,30,40};
    int n=4,pos=2,item=25;

    for(int i=n;i>pos;i--)
        arr[i]=arr[i-1];

    arr[pos]=item;
    n++;

    printf("After Insertion:\n");
    for(int i=0;i<n;i++)
        printf("%d ",arr[i]);

    pos=3;

    for(int i=pos;i<n-1;i++)
        arr[i]=arr[i+1];

    n--;

    printf("\nAfter Deletion:\n");
    for(int i=0;i<n;i++)
        printf("%d ",arr[i]);

    return 0;
}
