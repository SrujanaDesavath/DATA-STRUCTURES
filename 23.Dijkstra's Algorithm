#include <stdio.h>

int main() {
    int cost[4][4] = {
        {0,1,4,0},
        {1,0,2,6},
        {4,2,0,3},
        {0,6,3,0}
    };

    int dist[4]={0,999,999,999};
    int visited[4]={0};

    for(int c=0;c<3;c++) {
        int min=999,u;

        for(int i=0;i<4;i++)
            if(!visited[i] && dist[i]<min) {
                min=dist[i];
                u=i;
            }

        visited[u]=1;

        for(int v=0;v<4;v++)
            if(cost[u][v] && dist[u]+cost[u][v]<dist[v])
                dist[v]=dist[u]+cost[u][v];
    }

    for(int i=0;i<4;i++)
        printf("%d ",dist[i]);

    return 0;
}
