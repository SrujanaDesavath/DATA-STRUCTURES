#include <stdio.h>

#define MAX 5

int queue[MAX];
int front=-1,rear=-1;

void enqueue(int item) {
    if(front==-1)
        front=0;
    queue[++rear]=item;
}

void dequeue() {
    printf("Deleted Element: %d\n",queue[front++]);
}

void display() {
    for(int i=front;i<=rear;i++)
        printf("%d ",queue[i]);
    printf("\n");
}

int main() {
    enqueue(10);
    enqueue(20);
    enqueue(30);

    display();
    dequeue();
    display();

    return 0;
}
