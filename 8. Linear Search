#include <stdio.h>

int main() {
    int arr[]={10,20,30,40,50};
    int key=30,found=0;

    for(int i=0;i<5;i++) {
        if(arr[i]==key) {
            printf("Element Found at Position %d",i+1);
            found=1;
            break;
        }
    }

    if(!found)
        printf("Element Not Found");

    return 0;
}
