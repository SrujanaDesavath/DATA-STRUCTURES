#include <stdio.h>

int main() {
    int arr[]={10,20,30,40,50};
    int low=0,high=4,key=40,mid;

    while(low<=high) {
        mid=(low+high)/2;

        if(arr[mid]==key) {
            printf("Element Found at Position %d",mid+1);
            return 0;
        }
        else if(key<arr[mid])
            high=mid-1;
        else
            low=mid+1;
    }

    printf("Element Not Found");

    return 0;
}
